{
  "$schema": "https://turbo.build/schema.json",
  "ui": "stream",
  "globalDependencies": ["**/.env.*", "tsconfig.base.json"],
  "globalEnv": [
    "NEXT_PUBLIC_*",
    "CONVEX_DEPLOYMENT",
    "CONVEX_DEPLOY_KEY",
    "CLERK_SECRET_KEY",
    "OPENAI_API_KEY",
    "ONESIGNAL_REST_API_KEY",
    "SENTRY_DSN",
    "MEILISEARCH_URL",
    "MEILISEARCH_ADMIN_KEY",
    "MEILISEARCH_SEARCH_KEY"
  ],
  "tasks": {
    "build": {
      "dependsOn": ["^build"],
      "outputs": [".next/**", "!.next/cache/**", "dist/**", "storybook-static/**"]
    },
    "build-storybook": {
      "dependsOn": ["^build"],
      "outputs": ["storybook-static/**"]
    },
    "lint": {
      "dependsOn": ["^build"]
    },
    "typecheck": {
      "dependsOn": ["^build"]
    },
    "test": {
      "dependsOn": ["^build"],
      "outputs": ["coverage/**"]
    },
    "dev": {
      "cache": false,
      "persistent": true
    },
    "clean": {
      "cache": false
    }
  }
}
