# ============================================================
# GeoCanvas — Environment Variables (web app)
# ============================================================
# Copy this file to `.env.local` and fill in the values.
# Every value below must be obtained manually — see the URL in each comment.
# Do NOT commit `.env.local`. Do NOT invent placeholder credentials.
# ============================================================

# ---- Convex (backend) ----
# Get: run `npx convex dev` in apps/web once you've created a project at
# https://dashboard.convex.dev — the CLI writes this automatically.
NEXT_PUBLIC_CONVEX_URL=""

# ---- MapTiler (map tiles) ----
# Get: https://cloud.maptiler.com/account/  → "Keys" → New key
NEXT_PUBLIC_MAPTILER_API_KEY=""

# ---- Clerk (authentication) ----
# Get: https://dashboard.clerk.com  → Create app → API Keys
# Phase 0 ships Google + email + phone. Apple Sign-In added later.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# For Google OAuth, create credentials at
# https://console.cloud.google.com → APIs & Services → Credentials
# and paste the redirect URI shown in Clerk's Google provider settings.

# ---- Meilisearch Cloud (search) ----
# Get: https://meilisearch.com/cloud  → create instance → "API keys"
NEXT_PUBLIC_MEILISEARCH_URL=""
NEXT_PUBLIC_MEILISEARCH_SEARCH_KEY=""
MEILISEARCH_ADMIN_KEY=""

# ---- OneSignal (push notifications) ----
# Get: https://dashboard.onesignal.com  → New app → Web Push → Keys
NEXT_PUBLIC_ONESIGNAL_APP_ID=""
ONESIGNAL_REST_API_KEY=""

# ---- OpenAI (moderation Tier 2 only — can defer) ----
# Get: https://platform.openai.com/api-keys
OPENAI_API_KEY=""

# ---- Sentry (error tracking) ----
# Get: https://sentry.io  → New project (Next.js) → DSN
NEXT_PUBLIC_SENTRY_DSN=""
SENTRY_DSN=""

# ---- PostHog (analytics + feature flags) ----
# Get: https://app.posthog.com  → New project → Project settings
NEXT_PUBLIC_POSTHOG_KEY=""
NEXT_PUBLIC_POSTHOG_HOST="https://app.posthog.com"
